BAIDUPAN_APP_NAME=your_app_name_here
BAIDUPAN_CRYPTO_PASSPHRASE=your_crypto_passphrase_here

# Local direct-auth mode for development
BAIDUPAN_APP_KEY=your_app_key_here
BAIDUPAN_APP_SECRET=your_app_secret_here

# Client production mode: point the CLI at your deployed auth service instead of
# shipping BAIDUPAN_APP_SECRET to end users.
# BAIDUPAN_AUTH_SERVER=https://auth.example.com

# Auth server deployment mode
# BAIDUPAN_AUTH_SERVER_BIND=0.0.0.0:28681
